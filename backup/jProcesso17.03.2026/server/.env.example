# ========================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# ========================================

# PostgreSQL - Configuração Real
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jprocesso_global
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=tenant_teste

# ========================================
# SEGURANÇA
# ========================================

# JWT Secret - Use uma string aleatória com no mínimo 32 caracteres
JWT_SECRET=sua_chave_secreta_super_segura_aqui_minimo_32_chars

# ========================================
# MODO DE OPERAÇÃO
# ========================================

# Usar dados mock (true) ou banco real (false)
USE_MOCK_AUTH=false

# ========================================
# SERVIDOR
# ========================================

PORT=5000
NODE_ENV=development

# ========================================
# UPLOAD DE ARQUIVOS
# ========================================

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ========================================
# CORS
# ========================================

# URL do frontend
CLIENT_URL=http://localhost:3000
